@model Business.PRO_USU_USUARIO

@{
    ViewBag.Title = "Criação de Usuário";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <body class="bg-dark">
        <div class="container">
            <div class="card card-register mx-auto mt-5">
                <div class="card-header">Registrar Usuário</div>
                <div class="card-body">
                    <form>
                        <div class="form-group">
                            <div class="form-row">
                                <div class="col-md-6">
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                    <div class="form-group">
                                        @Html.Label("Login")
                                        @Html.EditorFor(model => model.USU_C_NOME, new { htmlAttributes = new { @class = "form-control" } })
                                        @Html.ValidationMessageFor(model => model.USU_C_NOME, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <div class="form-row">
                                <div class="col-md-6">
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                    <div class="form-group">
                                        @Html.Label("Senha")
                                        @Html.EditorFor(model => model.USU_C_SENHA, new { htmlAttributes = new { @class = "form-control", @Type = "password"} })
                                        @Html.ValidationMessageFor(model => model.USU_C_SENHA, "", new { @class = "text-danger" })   
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <div class="form-row">
                                <div class="col-md-6">
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                    <div class="form-group">
                                        @Html.Label("Ativo")
                                        @Html.DropDownListFor(modelItem => modelItem.USU_C_ATIVO, new[] { new SelectListItem { Text = "Sim", Value = "true" }, new SelectListItem { Text = "Não", Value = "false" } }, new { @class = "form-control" })
                                    </div>
                                </div>
                            </div>
                        </div>
                        <input type="submit" value="Salvar" class="btn btn-primary btn-block" />
                    </form>
                </div>
            </div>
        </div>
      
    </body>
}

<div>
    @Html.ActionLink("Voltar", "Index")
</div>
