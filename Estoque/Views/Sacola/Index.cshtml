
@{
    ViewBag.Title = "Sacola";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@using (Html.BeginForm("Index", "Sacola", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <body class="bg-dark">
        <div class="container">
            <div class="card card-body mx-0 mt-5">
                <div class="card-header">Imprimir</div>
                <div class="card-body">
                    <form id="FrmCreate" action="Produtos/Create">
                        <div class="form-group">
                            <div class="form-row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <div id="TextBoxContainer"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <select class="js-example-basic-multiple form-control" name="states[]" multiple="multiple">
                                @foreach (var item in ViewBag.Sacola)
                                {
                                    <option value="@item.PRO_N_REFERENCIA">@item.PRO_N_REFERENCIA</option>
                                }
                            </select>
                        </div>
                        <input type="submit" value="Criar Lista" class="btn btn-dark jqEnviar"/>
                    </form>
                </div>
            </div>
        </div>
    </body>
}
<script src="http://ajax.googleapis.com/ajax/libs/jquery/1.7.1/jquery.min.js" type="text/javascript"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.0/js/select2.min.js"></script>
<script>
    $(document).ready(function () {
        $(".js-example-basic-multiple").select2({
            placeholder: "Insira o código de Referência",
            allowClear: true
        });
    });
</script>



